# Server
PORT=3000
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/orders_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-admin-group-chat-id
TELEGRAM_WEB_APP_URL=https://your-app.railway.app
# Optional: My Taxi deep-link template for delivery location in Telegram messages.
# Placeholders: {lat} and {lng} (or {lon}), example: mytaxi://route?end_lat={lat}&end_lon={lng}
MY_TAXI_URL_TEMPLATE=
# Optional: Millenium Taxi deep-link template for delivery location in Telegram messages.
# Placeholders: {lat} and {lng} (or {lon}), example: milleniumtaxi://route?end_lat={lat}&end_lon={lng}
MILLENIUM_TAXI_URL_TEMPLATE=

# Frontend URL
FRONTEND_URL=https://your-app.railway.app

# Uploads
UPLOADS_DIR=/data/uploads

# Admin credentials (for first admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password




