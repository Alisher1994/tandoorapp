# Server
PORT=3000
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/orders_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-admin-group-chat-id
TELEGRAM_WEB_APP_URL=https://your-app.railway.app
# Optional webhook secret for Telegram (recommended in production)
# Must match the secret_token used in setWebhook
TELEGRAM_WEBHOOK_SECRET=
# Set to 0 to remove the chat-bar "Open" Web App button for all store bots (silent; restart server).
# Reply keyboard "Заказать" is unchanged. Default: 1 (enabled).
TELEGRAM_WEBAPP_MENU_BUTTON_ENABLED=1
# Optional: My Taxi link template for delivery location in Telegram messages.
# Placeholders: {lat} and {lng} (or {lon}), example: mytaxiapp://start?q={lat},{lng}
MY_TAXI_URL_TEMPLATE=
# Optional: Millenium Taxi deep-link template for delivery location in Telegram messages.
# App currently registers app_name://order (opens app). If Millennium provides destination params,
# you can use placeholders: {lat} and {lng} (or {lon}).
MILLENIUM_TAXI_URL_TEMPLATE=
# Optional: same templates for frontend operator panel links (Vite env).
VITE_MY_TAXI_URL_TEMPLATE=
VITE_MILLENIUM_TAXI_URL_TEMPLATE=

# Frontend URL
FRONTEND_URL=https://your-app.railway.app
# Optional extra CORS origins (comma-separated), e.g. https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=
# CSP in report-only mode (recommended true while tuning)
CSP_REPORT_ONLY=true

# Uploads
UPLOADS_DIR=/data/uploads

# Optional AI preview for global products (generation + transparent processing)
# If GEMINI_API_KEY is not set, server will fallback to Pollinations for generation.
GEMINI_API_KEY=
# Optional explicit Gemini image model (defaults are tried automatically)
GEMINI_IMAGE_MODEL=

# Optional OpenRouter provider defaults (used when no active AI provider is selected in panel)
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=stepfun/step-3.5-flash:free
OPENROUTER_IMAGE_MODEL=minimax/minimax-m2.5:free
# Optional OpenRouter headers (recommended)
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Talablar Superadmin

# Admin credentials (for first admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password




