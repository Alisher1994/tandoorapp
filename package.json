{
  "name": "order-management-system",
  "version": "1.0.0",
  "description": "Система управления заказами с Telegram ботом",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm ci --no-audit --no-fund && npm run build",
    "start": "node server/index.js",
    "migrate": "node server/database/migrate.js",
    "backfill:product-thumbs": "node scripts/backfill-product-thumbs.js",
    "backfill:ad-events-analytics": "node scripts/backfill-ad-banner-events-analytics.js",
    "refresh:customer-keyboards": "node scripts/refresh-customer-keyboards.js",
    "force:webapp:refresh": "node scripts/force-webapp-hard-refresh.js"
  },
  "keywords": [
    "orders",
    "telegram",
    "bot",
    "ecommerce"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "geoip-lite": "^2.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-telegram-bot-api": "^0.64.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
