{
  "name": "talablar-agent",
  "version": "8.10.0",
  "description": "Local printer agent for Talablar Restaurant Management",
  "main": "agent.js",
  "scripts": {
    "start": "node agent.js",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/TalablarAgent.exe"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.4",
    "get-pixels": "^3.3.3",
    "jimp": "^0.22.12",
    "socket.io-client": "^4.7.2",
    "webp-converter": "^2.3.3"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "bin": "agent.js",
  "pkg": {
    "assets": [
      "package.json",
      ".env.example",
      "README.md",
      "node_modules/webp-converter/bin/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  }
}
